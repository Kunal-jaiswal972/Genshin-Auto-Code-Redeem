{
  "name": "auto-code-redeemer",
  "version": "2.0.0",
  "description": "Modular multi-game promo code scraper and redeemer",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "cron": "cross-env EXECUTION_MODE=cron tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "cron:prod": "cross-env EXECUTION_MODE=cron node dist/index.js",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc -p tsconfig.typecheck.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "puppeteer-core": "^24.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
