# ── Execution ──────────────────────────────────────────────────────────────
# manual = interactive scrape prompt (npm run start)
# cron   = autonomous scheduled run (npm run cron)
EXECUTION_MODE=manual

# Active game adapter key (must match a folder under src/games/)
GAME_ID=genshin

# ── Code store (JSON file, one file per instance) ───────────────────────────
CODE_STORE_PATH=./src/data/codes.json

# ── Chrome / Puppeteer (puppeteer-core) ─────────────────────────────────────
# Leave empty to auto-detect chrome.exe on Windows
CHROME_EXECUTABLE_PATH=

# Dedicated debug profile (same pattern as MAL_Bulk_FriendReq_Sender)
# Log into Hoyoverse here once; sessions persist across runs.
CHROME_USER_DATA_DIR=%LOCALAPPDATA%\Google\Chrome\DebugProfile

# Remote debugging port used when launching Chrome
CHROME_DEBUG_PORT=9222

# true|1|yes|on to run Chrome headless (required for unattended cron on VM)
HEADLESS=false

# ── Genshin credentials (required — both manual and cron use .env only) ─────
GENSHIN_EMAIL=you@example.com
GENSHIN_PASSWORD=
GENSHIN_SERVER=Asia

# ── Future: email reporting (yt-webhook snippet) ────────────────────────────
# REPORT_EMAIL_TO=
# REPORT_EMAIL_FROM=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
