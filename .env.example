# ── Storage ───────────────────────────────────────────────────────────────────

# Per-game scraped codes live at <CODE_STORE_BASE_PATH>/<gameId>/codes.json
# dev: required (default below)  |  prod: required — e.g. /data/codes (mount a volume)
CODE_STORE_BASE_PATH=./src/data

# Scheduled tasks + run history (SQLite) or schedules-only JSON fallback
# dev: required (default below)  |  prod: required — e.g. file:/data/redeemer.db
DATABASE_URL=file:./src/data/redeemer.db
# JSON fallback (no run history): DATABASE_URL=json:./src/data/scheduled-tasks.json

# How often the scheduler checks for due tasks (ms). Min 5000. Default 60000.
# dev + prod: optional (default 60000) — applies whenever the process runs (dev and prod both start the scheduler)
SCHEDULER_POLL_INTERVAL_MS=60000

# ── Chrome / Puppeteer ──────────────────────────────────────────────────────

# Browser binary. Empty = auto-detect Chrome/Edge on Windows.
# dev: optional  |  prod: required in Docker — e.g. /usr/bin/chromium
CHROME_EXECUTABLE_PATH=

# Persistent profile for Hoyoverse login session.
# dev: recommended  |  prod: required — e.g. /data/chrome (mount a volume)
CHROME_USER_DATA_DIR=%LOCALAPPDATA%\Google\Chrome\DebugProfile

# Remote debugging port when attaching to an existing Chrome instance.
# dev: optional (default 9222)  |  prod: optional (unused when HEADLESS=true)
CHROME_DEBUG_PORT=9222

# Run browser without a visible window.
# dev: optional (false is easier for debugging)  |  prod: required (true)
HEADLESS=false

# ── Input adapters ──────────────────────────────────────────────────────────

# Terminal menu (Run now, Schedule, List, …). Same registry for npm run dev and npm start.
# dev: recommended true  |  prod: false in Docker (no TTY); true on VPS with SSH
CLI_ADAPTER_ENABLED=true

# ── Telegram ────────────────────────────────────────────────────────────────

# Bot token from @BotFather.
# dev + prod: required when TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=

# Enable or disable the bot. When unset, enabled if TELEGRAM_BOT_TOKEN is set.
# dev + prod: optional — set false to disable bot while keeping token
TELEGRAM_ENABLED=true
